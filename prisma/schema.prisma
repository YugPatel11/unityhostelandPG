generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("OWNER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id          String    @id @default(cuid())
  roomNumber  String    @unique
  floor       Int
  roomType    String    // e.g., "Single", "Double", "Triple"
  totalBeds   Int
  monthlyRent Int       // Base rent for this room type per bed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  students    Student[]
}

model Student {
  id              String    @id @default(cuid())
  fullName        String
  photoUrl        String?
  mobileNumber    String    @unique
  parentName      String
  parentMobile    String
  aadhaarNumber   String    @unique
  address         String
  college         String?
  course          String?
  checkInDate     DateTime
  securityDeposit Int       @default(0)
  monthlyRent     Int
  emergencyContact String
  idProofUrl      String?
  status          String    @default("ACTIVE") // ACTIVE, LEFT

  roomId          String?
  room            Room?     @relation(fields: [roomId], references: [id])
  assignedBed     String?   // E.g., "A", "B", "1", "2"
  
  payments        Payment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  amount      Int
  month       DateTime // Store the first day of the month this payment is for
  status      String   @default("PENDING") // PENDING, PAID, LATE
  paidDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  category    String   // Electricity, Water, Internet, etc.
  amount      Int
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
